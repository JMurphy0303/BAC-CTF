@model CtfApp.Models.Document
@{
    ViewData["Title"] = Model.Title;
    var isFlag = Model.Id == 6;
}

<div class="card" style="@(isFlag ? "border-color:#f85149" : "")">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
        <h2 style="color:#c9d1d9;font-size:1.1rem">@Model.Title</h2>
        @if (isFlag)
        {
            <span class="confidential-badge"></span>
        }
    </div>

    @if (isFlag)
    {
        <p style="color:#000000;font-size:0.85rem;margin-bottom:0.75rem">
            You have successfully exploited an Insecure Direct Object Reference (IDOR) vulnerability
            and accessed a confidential document that does not belong to your account.
        </p>
        <div class="flag-box">@Model.Content</div>
    }
    else
    {
        <div style="background:#0d1117;border:1px solid #30363d;border-radius:6px;padding:1.25rem;font-size:0.92rem;line-height:1.7;color:#c9d1d9">
            @Model.Content
        </div>
    }

    <div style="margin-top:1.5rem">
        <a class="btn" href="/Home/Dashboard">← Back to My Documents</a>
    </div>
</div>
